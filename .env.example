# ===========================================
# Tiki Village - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ===========================================
# DATABASE (PostgreSQL) - REQUIRED
# ===========================================
DATABASE_URL=postgresql://tikivillage:changeme@localhost:5432/tikivillage

# ===========================================
# PAYLOAD CMS - REQUIRED
# ===========================================
# Secret key for Payload (minimum 32 characters)
PAYLOAD_SECRET=your-secret-key-minimum-32-characters-here

# ===========================================
# APPLICATION
# ===========================================
# Server URL (change for production)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ===========================================
# PAYZEN PAYMENT GATEWAY (Optional for development)
# ===========================================
# Contact OSB/Lyra Network for credentials
# PAYZEN_SHOP_ID=your_shop_id
# PAYZEN_MODE=TEST
# PAYZEN_TEST_KEY=your_test_key
# PAYZEN_PROD_KEY=your_prod_key
# PAYZEN_HMAC_TEST_KEY=your_hmac_test_key
# PAYZEN_HMAC_PROD_KEY=your_hmac_prod_key
# PAYZEN_PUBLIC_TEST_KEY=your_public_test_key
# PAYZEN_PUBLIC_PROD_KEY=your_public_prod_key

# ===========================================
# EMAIL SMTP (Microsoft Exchange Online)
# ===========================================
# Required for sending order confirmation emails
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_USER=vaimoe@tikivillage.pf
SMTP_PASSWORD=your-smtp-password-here
SMTP_FROM=accueil@tikivillage.pf
SMTP_ADMIN_EMAIL=accueil@tikivillage.pf

# ===========================================
# SEED TOKEN (For database seeding)
# ===========================================
# Token to protect seed endpoints
# SEED_TOKEN=your-random-seed-token-here
